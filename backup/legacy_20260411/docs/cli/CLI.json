{
  "title": "OpenClaw CLI Reference",
  "version": "2026-04-10",
  "source_zh": "openclawx.cloud/zh/cli",
  "source_en": "openclawx.cloud/en/cli",
  "global_flags": [
    {"flag": "--dev", "description": "将状态隔离在 ~/.openclaw-dev 下，并移动默认端口"},
    {"flag": "--profile <name>", "description": "将状态隔离在 ~/.openclaw-<name> 下"},
    {"flag": "--no-color", "description": "禁用 ANSI 颜色"},
    {"flag": "--update", "description": "openclaw update 的简写（仅限源码安装）"},
    {"flag": "-V, --version, -v", "description": "打印版本并退出"}
  ],
  "command_tree": {
    "setup": {"description": "初始化配置 + 工作区", "options": ["--workspace", "--wizard", "--non-interactive", "--mode", "--remote-url", "--remote-token"]},
    "onboard": {"description": "交互式向导，设置网关、工作区和技能", "options": ["--workspace", "--reset", "--non-interactive", "--mode", "--auth-choice", "--token-provider", "--token", "--gateway-port", "--gateway-bind", "--gateway-auth", "--gateway-token", "--remote-url", "--remote-token", "--tailscale", "--install-daemon", "--skip-channels", "--skip-skills", "--skip-health", "--node-manager"]},
    "configure": {"description": "交互式配置向导（模型、频道、技能、网关）"},
    "config": {"subcommands": {"get": "打印配置值", "set": "设置值（JSON5 或原始字符串）", "unset": "移除值", "file": "打印活动配置文件路径", "validate": "验证当前配置是否符合模式"}},
    "doctor": {"description": "健康检查 + 快速修复", "options": ["--no-workspace-suggestions", "--yes", "--non-interactive", "--deep"]},
    "channels": {"subcommands": {"list": "显示已配置的频道和身份验证配置文件", "status": "检查网关可达性和频道健康状况", "logs": "显示网关日志文件中的近期频道日志", "add": "设置频道账户", "remove": "移除频道账户", "login": "交互式频道登录（仅限 WhatsApp Web）", "logout": "登出频道会话"}, "common_options": ["--channel", "--account", "--name"]},
    "skills": {"subcommands": {"list": "列出技能", "info": "显示一个技能的详细信息", "check": "就绪与缺失要求的摘要"}, "options": ["--eligible", "--json", "-v"]},
    "pairing": {"subcommands": {"list": "列出配对请求", "approve": "批准配对请求"}},
    "devices": {"subcommands": {"list": "列出设备配对条目", "approve": "批准设备", "reject": "拒绝设备", "remove": "移除设备", "clear": "清除设备", "rotate": "轮换设备令牌", "revoke": "撤销设备令牌"}},
    "plugins": {"subcommands": {"list": "发现插件", "info": "显示插件的详细信息", "install": "安装插件", "enable": "启用插件", "disable": "禁用插件", "doctor": "报告插件加载错误"}},
    "memory": {"subcommands": {"status": "显示索引统计信息", "index": "重新索引记忆文件", "search": "对记忆进行语义搜索"}},
    "models": {"subcommands": {"list": "显示已配置的模型", "status": "显示已解析的主模型、回退模型、图像模型和认证概览", "set": "设置主模型", "set-image": "设置图像模型", "aliases": "别名管理", "fallbacks": "回退管理", "image-fallbacks": "图像回退管理", "scan": "扫描 OpenRouter 免费模型", "auth": "认证管理"}},
    "cron": {"subcommands": {"status": "显示 cron 状态", "list": "列出定时任务", "add": "添加定时任务", "edit": "编辑定时任务", "rm": "删除定时任务", "enable": "启用定时任务", "disable": "禁用定时任务", "runs": "查看运行记录", "run": "手动运行"}},
    "gateway": {"description": "运行 WebSocket 网关", "options": ["--port", "--bind", "--token", "--auth", "--password", "--tailscale", "--allow-unconfigured", "--dev", "--reset", "--force", "--verbose", "--ws-log"]},
    "nodes": {"description": "与网关通信并定位已配对的节点", "subcommands": {"status": "节点状态", "describe": "描述节点", "list": "列出节点", "pending": "待批准节点", "approve": "批准节点", "reject": "拒绝节点", "invoke": "调用节点命令", "run": "在节点上运行命令"}, "capabilities": {"camera": ["list", "snap", "clip"], "canvas": ["snapshot", "present", "hide", "navigate", "eval", "a2ui_push", "a2ui_reset"], "screen": ["record"], "location": ["get"]}},
    "browser": {"description": "浏览器控制 CLI（专用 Chrome/Brave/Edge/Chromium）", "subcommands": {"status": "浏览器状态", "start": "启动浏览器", "stop": "停止浏览器", "reset-profile": "重置配置文件", "tabs": "标签页管理", "open": "打开 URL", "focus": "聚焦标签", "close": "关闭标签", "profiles": "配置文件管理", "screenshot": "截图", "snapshot": "快照", "navigate": "导航", "resize": "调整大小", "click": "点击", "type": "输入文本", "press": "按键", "hover": "悬停", "drag": "拖拽", "select": "选择", "upload": "上传文件", "fill": "填写表单", "dialog": "对话框处理", "wait": "等待", "evaluate": "执行 JS", "console": "控制台", "pdf": "生成 PDF"}},
    "security": {"description": "安全审计", "subcommands": {"audit": "审计配置 + 本地状态，查找常见的安全隐患", "audit --deep": "尽力对网关进行实时探测", "audit --fix": "收紧安全默认值并对状态/配置进行 chmod"}},
    "secrets": {"subcommands": {"reload": "重新解析引用并以原子方式交换运行时快照", "audit": "扫描明文残留、未解析的引用和优先级漂移", "configure": "交互式助手", "apply": "应用计划"}},
    "status": {"description": "显示链接的会话健康状况和最近的收件人", "options": ["--json", "--all", "--deep", "--usage", "--timeout", "--verbose"]},
    "health": {"description": "从正在运行的网关获取健康状态", "options": ["--json", "--timeout", "--verbose"]},
    "sessions": {"description": "列出存储的对话会话", "options": ["--json", "--verbose", "--store", "--active"]},
    "logs": {"description": "通过 RPC 跟踪网关文件日志", "options": ["--follow", "--limit", "--plain", "--json", "--no-color"]},
    "agent": {"description": "通过网关运行一个代理轮次", "required": ["--message"], "options": ["--to", "--session-id", "--thinking", "--verbose", "--channel", "--local", "--deliver", "--json", "--timeout"]},
    "agents": {"description": "管理隔离的代理", "subcommands": {"list": "列出已配置的代理", "add": "添加新的隔离代理", "bindings": "列出路由绑定", "bind": "添加路由绑定", "unbind": "移除路由绑定", "delete": "删除代理并清理其工作区 + 状态"}},
    "message": {"description": "统一的外发消息 + 频道操作", "subcommands": ["send", "poll", "react", "reactions", "read", "edit", "delete", "pin", "unpin", "pins", "permissions", "search", "timeout", "kick", "ban", "thread", "emoji", "sticker", "role", "channel", "member", "voice", "event"]},
    "acp": {"description": "运行连接 IDE 到网关的 ACP 桥接器"},
    "system": {"subcommands": {"event": "将系统事件加入队列", "heartbeat": "心跳控制", "presence": "列出系统在线状态条目"}},
    "reset": {"description": "重置本地配置/状态", "options": ["--scope", "--yes", "--non-interactive", "--dry-run"]},
    "uninstall": {"description": "卸载网关服务 + 本地数据（CLI 保留）", "options": ["--service", "--state", "--workspace", "--app", "--all", "--yes", "--non-interactive", "--dry-run"]},
    "update": {"description": "运行更新 + 重启 + 唤醒"},
    "tui": {"description": "打开连接到网关的终端 UI", "options": ["--url", "--token", "--password", "--session", "--deliver", "--thinking", "--message", "--timeout-ms"]},
    "docs": {"description": "搜索在线文档索引"},
    "dns": {"description": "广域发现 DNS 助手（CoreDNS + Tailscale）", "options": ["--apply"]},
    "webhooks": {"subcommands": {"gmail": "Gmail Pub/Sub 钩子设置 + 运行器"}},
    "daemon": {"description": "网关服务命令的旧别名"},
    "clawbot": {"description": "旧别名命名空间"}
  },
  "color_palette": {
    "accent": "#FF5A2D",
    "accentBright": "#FF7A3D",
    "accentDim": "#D14A22",
    "info": "#FF8A5B",
    "success": "#2FBF71",
    "warn": "#FFB020",
    "error": "#E23D2D",
    "muted": "#8B7F77"
  },
  "output_styling": [
    "ANSI 颜色和进度指示器仅在 TTY 会话中渲染",
    "OSC-8 超链接在支持的终端中渲染为可点击链接",
    "--json（以及支持的 --plain）禁用样式以获得干净输出",
    "长时间运行的命令会显示进度指示器"
  ]
}
